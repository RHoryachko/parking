# PostgreSQL (Docker / prod). For local dev without Docker use SQLite (default in app config).
# DATABASE_URL=postgresql://parking:parking@localhost:5432/parking
# DATABASE_URL=postgresql://parking:parking@db:5432/parking
DATABASE_URL=sqlite:///./parking.db
# SQLite: tables are created on API startup — do not run Alembic. PostgreSQL: alembic upgrade head + seed.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRES_MIN=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080,http://localhost:8080
# --- LiqPay (тільки бекенд) — sandbox за замовчуванням у коді; для prod задай ключі тут ---
# Порожні значення в .env ігноруються (env_ignore_empty), щоб не затирати дефолти.
# Ключі з кабінету https://www.liqpay.ua (sandbox для тестів).
# Скопіюй цей файл як .env у тій самій папці (backend/.env) і підстав значення.
# Публічна URL API (без /api в кінці). LiqPay викликає server_url з інтернету: localhost часто дає помилку після картки — для тестів ngrok/cloudflared.
APP_PUBLIC_API_URL=http://127.0.0.1:8010
# Flutter web (порт як у `flutter run -d chrome --web-port=8080`). Порожній LIQPAY_RESULT_URL → сторінка подяки у клієнті
CLIENT_APP_WEB_URL=http://127.0.0.1:8080
# Порожньо: LiqPay після оплати → CLIENT_APP_WEB_URL/payment-success?booking_id=…
# Свій URL: LIQPAY_RESULT_URL=https://app.example/thanks
LIQPAY_RESULT_URL=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
# Якщо .env не в backend/ або uvicorn стартує з іншого cwd — абсолютний шлях до файлу з LIQPAY_*:
# LIQPAY_DOTENV_PATH=C:/projects/parking/backend/.env

# --- kie.ai (Gemini 2.5 Flash, OpenAI-compatible) — розпізнавання номера з фото для /api/ai/gate/* ---
# Ключ: https://kie.ai/api-key (Bearer у заголовку Authorization).
KIE_AI_API_KEY=
# За потреби інший endpoint або модель:
# KIE_AI_CHAT_URL=https://api.kie.ai/gemini-2.5-flash/v1/chat/completions
# KIE_AI_MODEL=gemini-2.5-flash
